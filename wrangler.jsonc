{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "coasterhub",
  "main": "worker.js",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "coasterhub",
      "database_id": "d4742d82-f606-498a-8520-bcbfec7dcf91"
    }
  ]
}
